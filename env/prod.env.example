# Production env is generated from 1Password:
#   op inject -i env/prod.env.tpl -o env/prod.env
#
# Or just run: make env
#
# Secrets are stored in 1Password vault "infra", item "vibez"

PORT=3005
RADIO_URL=https://vibez.bike-shed.io
AUTH_PASSWORD=      # op://infra/vibez/auth-password
SLACK_BOT_TOKEN=    # op://infra/vibez/slack-bot-token
SLACK_APP_TOKEN=    # op://infra/vibez/slack-app-token
SOUNDCLOUD_CLIENT_ID=  # op://infra/vibez/soundcloud-client-id
