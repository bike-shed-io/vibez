# Local development env
# Production secrets are managed in 1Password (vault: infra, item: vibez)
# Run `make env` to generate env/prod.env from 1Password

# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Optional: Slack Incoming Webhook URL for join/DJ notifications
SLACK_NOTIFICATIONS_WEBHOOK_URL=

# Public URL where the radio web player is hosted (for Slack "Tune In" links)
RADIO_URL=http://localhost:3000

# Server port
PORT=3000
